POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your-neon-password
POSTGRES_HOST=your-project.pooler.neon.tech
POSTGRES_PORT=5432
PG_CONNECTION=Host=your-project.pooler.neon.tech;Port=5432;Database=neondb;Username=neondb_owner;Password=your-neon-password;SSL Mode=Require;Channel Binding=Require
FRONTEND_PORT=10000
API_PORT=8088
NODE_EVENTS_PORT=8090
VITE_API_BASE_URL=http://localhost:8088
VITE_NODE_EVENTS_URL=http://localhost:8090
VITE_ENABLE_DEMO_AUTH=false
JWT_KEY=<generate-at-least-64-random-characters>
TELEMETRY_DEVICE_SECRET=<generate-at-least-32-random-characters>
TELEMETRY_GATEWAY_SECRET=<generate-at-least-32-random-characters>
TELEMETRY_SIMULATOR_ENABLED=false
SSE_TICKET_KEY=<generate-at-least-32-random-characters>
PLATFORM_SUPERADMIN_EMAIL=<bootstrap-admin-email>
PLATFORM_SUPERADMIN_PASSWORD=<strong-unique-password>
DEMO_SEED_ENABLED=false
DEMO_SEED_PASSWORD=<set-only-when-demo-seeding-is-enabled>
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-password>
SMTP_FROM=<verified-sender-address>
STORAGE_BUCKET=<object-storage-bucket>
STORAGE_ACCESS_KEY=<object-storage-access-key>
STORAGE_SECRET_KEY=<object-storage-secret-key>
STORAGE_ENDPOINT=<s3-compatible-endpoint>
STORAGE_REGION=<storage-region>
DATA_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
DATA_ENCRYPTION_KEY_PREVIOUS=<optional-previous-base64-encoded-32-byte-key>
PII_INDEX_KEY=<base64-encoded-32-byte-hmac-key>
