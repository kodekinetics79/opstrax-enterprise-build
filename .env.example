# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_DATABASE=zayra
MYSQL_USER=zayra
MYSQL_PASSWORD=zayra_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=5117
FRONTEND_PORT=3000

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Only this variable is needed in Vercel for the frontend deployment.
# Set to your Railway (or other) backend URL in production.
# Vercel: NEXT_PUBLIC_API_BASE_URL=https://zayra-ai-workforce-production-2b92.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:5117

# ── JWT ───────────────────────────────────────────────────────────────────────
# Backend-only — never set these in Vercel frontend environment.
JWT_ISSUER=Zayra.Api
JWT_AUDIENCE=Zayra.Client
JWT_SIGNING_KEY=CHANGE_ME_TO_A_64_CHARACTER_PRODUCTION_SECRET_KEY_1234567890

# ── Platform Admin (backend-only) ─────────────────────────────────────────────
PLATFORM_ADMIN_EMAIL=platform@yourdomain.com
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PLATFORM_ADMIN_PASSWORD

# ── Seeding (backend-only) ────────────────────────────────────────────────────
SEED_TENANT_NAME=Zayra HQ
SEED_TENANT_SLUG=zayra
SEED_ADMIN_EMAIL=admin@zayra.local
SEED_ADMIN_NAME=Zayra Admin
SEED_ADMIN_PASSWORD=ChangeMe123!

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
